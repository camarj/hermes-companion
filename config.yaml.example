# ─────────────────────────────────────────────────────────────────────────────
# hermes-companion — main configuration
#
# Copy this file to `config.yaml` and edit the values below. The server loads
# `config.yaml` from the repo root at startup. If it can't find one, it falls
# back to this example file and prints a warning.
# ─────────────────────────────────────────────────────────────────────────────

# Identity shown to the model and in the UI.
assistant_name: "Companion"
company_name: "Your Company"
company_url: ""              # optional — appears in the default system prompt
default_language: "en"       # ISO code for the Realtime transcriber + greetings

# Personality blurb injected into the system prompt. Keep it short, conversational.
personality: >
  Warm, professional, and helpful. Speaks in short conversational sentences
  (2-3 sentences max in voice mode). No emojis, no markdown when speaking.

# ─────────────────────────────────────────────────────────────────────────────
# Team / users
#
# Each entry shows up on the login screen. Logged-in users get their name and
# role injected into the assistant's session context. Mark one entry with
# `shared_space: true` if you want a "meeting" account that everyone can see.
# ─────────────────────────────────────────────────────────────────────────────
team:
  - id: alice
    name: Alice
    role: CEO
  - id: bob
    name: Bob
    role: Engineering
  - id: shared
    name: Shared
    role: Group conversations
    shared_space: true

# ─────────────────────────────────────────────────────────────────────────────
# External agent (the thing that handles "live data" tool calls)
#
# When the model decides a question needs real data — past conversations,
# calendar, email, web search, automations — it invokes the `call_agent` tool.
# The server runs the command below as a subprocess and pipes the user's
# query as the first argument. The agent should print its answer to stdout.
#
# Default points to `hermes -z` (https://github.com/.../hermes-agent), but you
# can plug any CLI you like: a python script, another agent framework, an
# HTTP client, etc. The placeholders {query} and {user_id} are substituted
# at runtime.
#
# Env vars also passed to the subprocess:
#   AGENT_REQUESTER_ID, AGENT_REQUESTER_NAME, AGENT_REQUESTER_ROLE
# ─────────────────────────────────────────────────────────────────────────────
agent:
  # The label shown in the UI when a tool call is in flight ("Querying Hermes…").
  label: "Hermes"

  # If empty/null, the call_agent tool is disabled and the assistant runs in
  # voice-only mode. Otherwise this is the argv list of the subprocess.
  # The literal string "{query}" is replaced with the user's question.
  command:
    - hermes
    - chat
    - -q
    - "{query}"
    - --yolo

  timeout_seconds: 180

  # Optional: short description of what the agent can do — appended to the
  # system prompt so the model knows when to invoke it.
  description: >
    Hermes has access to live integrations (calendar, email, files, web search,
    scheduled tasks, persistent memory of past conversations). Use it whenever
    the user asks about real data or wants something done in the real world.

# ─────────────────────────────────────────────────────────────────────────────
# Optional: full custom system prompt. If set, this REPLACES the default
# template entirely — assistant_name/company_name/personality are ignored.
# Useful if you want full control over the model's behavior.
# ─────────────────────────────────────────────────────────────────────────────
# system_prompt: |
#   You are ...
