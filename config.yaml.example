# ─────────────────────────────────────────────────────────────────────────────
# hermes-companion — main configuration
#
# Copy this file to `config.yaml` and edit the values below. The server loads
# `config.yaml` from the repo root at startup. If it can't find one, it falls
# back to this example file and prints a warning.
# ─────────────────────────────────────────────────────────────────────────────

# Identity shown to the model and in the UI.
assistant_name: "Companion"
company_name: "Your Company"
company_url: ""              # optional — appears in the default system prompt
default_language: "en"       # ISO code for the Realtime transcriber + greetings

# Personality blurb injected into the system prompt. Keep it short, conversational.
personality: >
  Warm, professional, and helpful. Speaks in short conversational sentences
  (2-3 sentences max in voice mode). No emojis, no markdown when speaking.

# ─────────────────────────────────────────────────────────────────────────────
# Team / users
#
# Each entry shows up on the login screen. Logged-in users get their name and
# role injected into the assistant's session context. Mark one entry with
# `shared_space: true` if you want a "meeting" account that everyone can see.
# ─────────────────────────────────────────────────────────────────────────────
team:
  - id: alice
    name: Alice
    role: CEO
  - id: bob
    name: Bob
    role: Engineering
  - id: shared
    name: Shared
    role: Group conversations
    shared_space: true

# ─────────────────────────────────────────────────────────────────────────────
# Agents (the things that handle "live data" tool calls)
#
# When the model decides a question needs real data — past conversations,
# calendar, email, web search, automations — it invokes the `call_agent` tool.
# The backend routes the turn to the conversation's bound agent instance over
# ACP (Agent Client Protocol). Each instance is declared below; its `transport`
# selects the backend:
#   local-acp  → spawns `hermes acp` as a local subprocess
#   remote-acp → connects to a remote host-mode box over a WebSocket bridge
#
# Identity is passed to the agent via AGENT_REQUESTER_ID / _NAME / _ROLE (local)
# or X-Requester-* headers (remote). The first enabled agent is the default for
# new conversations; the UI can bind a conversation to any other.
# ─────────────────────────────────────────────────────────────────────────────
agents:
  - id: local-default
    label: "Hermes (local)"        # shown in the UI ("Querying Hermes…")
    type: hermes
    transport: local-acp           # runs `hermes acp` from PATH
    # system_prompt_override: |     # optional — materialized as AGENTS.md for the turn
    #   You are ...

  # A remote Hermes served by another box in host mode (see host_tokens below).
  # - id: vps-prod
  #   label: "Hermes VPS"
  #   type: hermes
  #   transport: remote-acp
  #   transport_config:
  #     url: "wss://my-host.example.com/api/host/acp"
  #     token: "env:VPS_HOST_TOKEN"   # literal, or env:VAR_NAME reference

# ─────────────────────────────────────────────────────────────────────────────
# Agent label + capability description.
#
# These feed the system prompt's routing block (when to use `call_agent`), so
# keep them even with the `agents:` list above. `description` should tell the
# model what the agent can do.
#
# Back-compat: if `agents:` is omitted entirely, this block is also
# auto-migrated to a single `local-default` instance (transport: local-acp).
# Any legacy `command:` / `timeout_seconds:` keys here are ignored —
# execution is always `hermes acp`.
# ─────────────────────────────────────────────────────────────────────────────
agent:
  label: "Hermes"
  description: >
    Hermes has access to live integrations (calendar, email, files, web search,
    scheduled tasks, persistent memory of past conversations). Use it whenever
    the user asks about real data or wants something done in the real world.

# ─────────────────────────────────────────────────────────────────────────────
# Optional: full custom system prompt. If set, this REPLACES the default
# template entirely — assistant_name/company_name/personality are ignored.
# Useful if you want full control over the model's behavior.
# ─────────────────────────────────────────────────────────────────────────────
# system_prompt: |
#   You are ...

# ─────────────────────────────────────────────────────────────────────────────
# Host mode — bearer tokens that authenticate remote `RemoteAcpBackend`
# clients hitting `/api/host/acp` (WebSocket bridge), the read-only inspection
# endpoints (`/api/host/skills|mcp|tools|config`), `/api/host/upload`, and
# `/api/host/config/system-prompt`.
#
# Enabling at least one token does NOT by itself enter host mode — that is
# controlled by the `HERMES_COMPANION_MODE=host` env var (see README → host
# mode). With host mode off these tokens are simply unused.
#
# Each token should be a long, unguessable string (32+ random chars). Store
# them on the client side (the `RemoteAcpBackend` config) so the client can
# send `Authorization: Bearer <token>` to the host.
# ─────────────────────────────────────────────────────────────────────────────
# host_tokens:
#   - token: "replace-with-a-long-random-string"
#     label: "vps-prod"
#   - token: "another-long-random-string"
#     label: "laptop-dev"
